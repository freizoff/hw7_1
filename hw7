class Iterable:
    def __init__ (self, data):
        self.data = data
    def __iter__(self):
        for item in self.data:
            yield item
            
my_list = Iterable([1, 3, 5, 7, 9])

gen = iter(my_list)


print(next(gen))
print(next(gen))
print(next(gen))
print(next(gen))
print(next(gen))
